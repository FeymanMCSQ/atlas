// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ContentMode {
  INFORMATION
  FOUNDER
}

model FeedSource {
  id          String    @id @default(uuid())
  name        String
  url         String    @unique
  isActive    Boolean   @default(true)
  category    String    @default("Engineering")
  lastFetched DateTime?


  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ContentItem {
  id           String      @id @default(uuid())
  source       String
  title        String
  url          String      @unique
  imageUrl     String?
  mode         ContentMode @default(INFORMATION)
  summary      String?
  sourceData   Json?      @default("{}")

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model PromptRun {
  id           String     @id @default(uuid())
  promptName   String
  model        String
  input        Json
  output       Json
  error        String?

  createdAt    DateTime   @default(now())
}

model Draft {
  id             String   @id @default(uuid())
  contentItemId  String
  platform       String   // "x" | "linkedin"
  body           String
  status         String   @default("pending") // "pending" | "approved" | "publishing" | "published" | "failed"
  qualityScore   Float?
  externalPostId String?  // Set after successful publish
  mediaUrl       String?  // Final generated/scraped visual media for publishing

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Transcript {
  id                 String   @id @default(uuid())
  audioFileReference String
  transcriptText     String   @db.Text
  confidence         Float?

  createdAt          DateTime @default(now())
}

model PostTemplate {
  id               String   @id @default(uuid())
  name             String
  hookArchetype    String   @db.Text
  formatStructure  String   @db.Text
  pacing           String   @db.Text
  examples         String   @db.Text
  
  createdAt        DateTime @default(now())
}

model SurveillanceTarget {
  id               String   @id @default(uuid())
  platform         String   // "linkedin" | "x"
  handle           String   @unique
  baselineAverage  Float    @default(0)
  postCount        Int      @default(0)

  createdAt        DateTime @default(now())
}

model ObservedPost {
  id               String   @id @default(uuid())
  targetId         String
  url              String   @unique
  content          String   @db.Text
  likes            Int
  comments         Int
  zScore           Float?

  createdAt        DateTime @default(now())
}

model ResonanceReport {
  id              String   @id @default(uuid())
  date            String   @unique // YYYY-MM-DD
  postsAnalyzed   Int      @default(0)
  postsInjected   Int      @default(0)
  reportItems     Json     // Array of { url, score, hookArchetype, whyItHelps }

  createdAt       DateTime @default(now())
}
