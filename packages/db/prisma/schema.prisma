// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model FeedSource {
  id          String    @id @default(uuid())
  name        String
  url         String    @unique
  isActive    Boolean   @default(true)
  lastFetched DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ContentItem {
  id           String     @id @default(uuid())
  source       String
  title        String
  url          String     @unique
  summary      String?
  sourceData   Json?      @default("{}")

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model PromptRun {
  id           String     @id @default(uuid())
  promptName   String
  model        String
  input        Json
  output       Json
  error        String?

  createdAt    DateTime   @default(now())
}
