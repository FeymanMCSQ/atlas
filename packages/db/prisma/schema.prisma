// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ContentMode {
  INFORMATION
  FOUNDER
}

model FeedSource {
  id          String    @id @default(uuid())
  name        String
  url         String    @unique
  isActive    Boolean   @default(true)
  lastFetched DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ContentItem {
  id           String      @id @default(uuid())
  source       String
  title        String
  url          String      @unique
  imageUrl     String?
  mode         ContentMode @default(INFORMATION)
  summary      String?
  sourceData   Json?      @default("{}")

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model PromptRun {
  id           String     @id @default(uuid())
  promptName   String
  model        String
  input        Json
  output       Json
  error        String?

  createdAt    DateTime   @default(now())
}

model Draft {
  id             String   @id @default(uuid())
  contentItemId  String
  platform       String   // "x" | "linkedin"
  body           String
  status         String   @default("pending") // "pending" | "approved" | "publishing" | "published" | "failed"
  qualityScore   Float?
  externalPostId String?  // Set after successful publish
  mediaUrl       String?  // Final generated/scraped visual media for publishing

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Transcript {
  id                 String   @id @default(uuid())
  audioFileReference String
  transcriptText     String   @db.Text
  confidence         Float?

  createdAt          DateTime @default(now())
}
